{
  "name": "quasar-docs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "npm run check:release",
    "build": "next build",
    "check:quickstart": "node scripts/check-quickstart-commands.mjs",
    "check:release": "npm run check:release-metadata && npm run check:quickstart",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "dev": "next dev",
    "start": "next start",
    "prepreview": "npm run check:release",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy": "npm run check:release",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preupload": "npm run check:release",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueshift-gg/quasar-docs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "overrides": {
    "postcss": "8.5.19"
  },
  "bugs": {
    "url": "https://github.com/blueshift-gg/quasar-docs/issues"
  },
  "homepage": "https://github.com/blueshift-gg/quasar-docs#readme",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/mdx": "^2.0.13",
    "fumadocs-core": "^16.6.17",
    "fumadocs-mdx": "^14.2.12",
    "fumadocs-ui": "^16.6.17",
    "next": "~16.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "8.5.19",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
